apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: mcast-fabric
  namespace: bitcoin-mcast
spec:
  config: |
    {
      "cniVersion": "0.3.1",
      "type": "macvlan",
      "master": "${FABRIC_IFACE}",
      "mode": "bridge",
      "ipam": { "type": "static" }
    }
