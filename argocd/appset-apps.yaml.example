# ArgoCD ApplicationSet — bitcoin workload fan-out (stub).
# Operator-supplied; not applied by this repo's tooling yet.
apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: bsv-mcast-retry
  namespace: argocd
spec:
  generators:
    - list:
        elements:
          - node: retry-1
            nackAddr: fd20::24
            tier: "0"
            preference: "128"
          - node: retry-2
            nackAddr: fd20::25
            tier: "0"
            preference: "64"
          - node: retry-3
            nackAddr: fd20::26
            tier: "1"
            preference: "128"
  template:
    metadata:
      name: 'retry-{{node}}'
    spec:
      project: default
      source:
        repoURL: oci://ghcr.io/lightwebinc/charts
        chart: retry-endpoint
        targetRevision: "0.1.0"
        helm:
          values: |
            config:
              nackAddr: "{{nackAddr}}"
              beaconTier: {{tier}}
              beaconPreference: {{preference}}
            nodeSelector:
              bsv-mcast/node: "{{node}}"
      destination:
        server: https://kubernetes.default.svc
        namespace: bsv-mcast
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
